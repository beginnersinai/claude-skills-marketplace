# Ensure GitHub Linguist counts Markdown in the language breakdown.
# Without this, GitHub treats .md as "documentation" and excludes it,
# so a plugin that's 99% Markdown shows as 100% HTML (because of a
# single heat-map-template.html file).
*.md linguist-detectable=true
*.md linguist-documentation=false

# Templates are reference files, not the primary language of the repo.
skills/**/templates/*.html linguist-generated=true
skills/**/templates/*.html linguist-documentation=true

# JSON config files are not the primary language.
.claude-plugin/plugin.json linguist-generated=true
